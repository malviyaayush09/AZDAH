# Supabase — get from https://app.supabase.com/project/_/settings/api
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Razorpay — get from https://dashboard.razorpay.com/app/keys
RAZORPAY_KEY_ID=rzp_live_xxxx
RAZORPAY_KEY_SECRET=your-secret
NEXT_PUBLIC_RAZORPAY_KEY_ID=rzp_live_xxxx

# WhatsApp Cloud API — get from https://developers.facebook.com
WHATSAPP_ACCESS_TOKEN=your-permanent-access-token
WHATSAPP_PHONE_NUMBER_ID=your-phone-number-id
WHATSAPP_ADMIN_NUMBER=919876543210

# App
NEXT_PUBLIC_APP_URL=https://azdahfit.in

# Auth — generate a random 32+ char string
SESSION_SECRET=change-this-to-a-random-secret-string-32chars

# Admin credentials (change before going live)
ADMIN_PHONE=919999999999
ADMIN_PASSWORD=azdah-admin-2024
